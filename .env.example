# Copier ce fichier en .env et renseigner tes identifiants INSEE.
# Le .env ne doit JAMAIS être commité.

# Jeton d'accès INSEE (portail-api.insee.fr)
# Va sur https://portail-api.insee.fr, connecte-toi, souscris à l'API "Données locales"
# puis récupère le "consumer key" et "consumer secret" dans ton application.
INSEE_CONSUMER_KEY=
INSEE_CONSUMER_SECRET=

# (optionnel) durée de cache des réponses API en secondes
CACHE_TTL_SECONDS=86400
